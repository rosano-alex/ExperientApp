{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/constants/*": ["./constants/*"],
      "@/constants": ["./`constants"],
      "@/core/*": ["./core/*"],
      "@/core": ["./`core"],
      "@/assets/*": ["./assets/*"],
      "@/assets": ["./`assets"],
      "@/components/*": ["./components/*"],
      "@/components": ["./`components"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
